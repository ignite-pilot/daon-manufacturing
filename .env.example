# =============================================================
# Profile 설정
# =============================================================
# default profile (AWS): .env.local 파일 없음 → Secrets Manager + S3 사용
# local profile (Docker): .env.local 파일 존재 → DB_HOST + MinIO 사용
#
# local profile 전환: npm run infra:up 후 npm run dev
# default profile 전환: .env.local 삭제
# =============================================================

# --- local profile (.env.local 에 복사해서 사용) ---
# PROFILE=local
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=daon
# DB_PASSWORD=daon1234
# DB_NAME=daon_manufacturing
# STORAGE_ENDPOINT=http://localhost:9000
# STORAGE_BUCKET=daon-mfg-local
# STORAGE_ACCESS_KEY=minioadmin
# STORAGE_SECRET_KEY=minioadmin123

# Anthropic Claude API (도면 분석)
# local profile: 직접 입력
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# default profile: AWS Secrets Manager "prod/ignite-pilot/claude/ANTHROPIC_API_KEY" 자동 조회

# DXF 분석 스크립트 (절대경로 권장)
# DXF_TO_SVG_SCRIPT=./scripts/analysis/dxf_to_svg.py
# PYTHON_EXECUTABLE=python3

# config-manager (config-manager.ig-pilot.com) 연동
# 앱 코드: 설정 화면과 동일하게 DAON_MFG
IG_CONFIG_APP_CODE=DAON_MFG
# API Key: 설정 화면에서 복사 (인증 헤더 Bearer 사용)
IG_CONFIG_API_KEY=your-api-key
# config-manager API 베이스 (미설정 시 https://config-manager.ig-pilot.com)
# CONFIG_MANAGER_API_URL=https://config-manager.ig-pilot.com
# 앱 ID (설정 화면 URL /apps/3/settings 일 때 3). 경로 시도 시 사용
# CONFIG_MANAGER_APP_ID=3
# PRODUCT_CODE 조회 전용 URL (실제 API 경로가 다르면 전체 URL 지정)
# CONFIG_MANAGER_PRODUCT_CODES_URL=https://config-manager.ig-pilot.com/api/...

# 완제품 코드 (공정 등록 '대상 완제품')
# IG_CONFIG_API_KEY 설정 시: 코드 관리(config-manager) API에서만 조회. 이 경우 PRODUCT_CODE 는 사용하지 않음(빈 값).
# PRODUCT_CODES_API_URL 설정 시: 해당 URL만 조회.
# config-manager 미사용 시에만: 아래처럼 쉼표 구분으로 입력
# PRODUCT_CODE=CODE1,CODE2
# PRODUCT_CODES_API_URL=https://config-manager.ig-pilot.com/api/...
