# API Keys (필요 시)
# OPENAI_API_KEY=

# config-manager (config-manager.ig-pilot.com) 연동
# 앱 코드: 설정 화면과 동일하게 DAON_MFG
IG_CONFIG_APP_CODE=DAON_MFG
# API Key: 설정 화면에서 복사 (인증 헤더 Bearer 사용)
IG_CONFIG_API_KEY=your-api-key
# config-manager API 베이스 (미설정 시 https://config-manager.ig-pilot.com)
# CONFIG_MANAGER_API_URL=https://config-manager.ig-pilot.com
# 앱 ID (설정 화면 URL /apps/3/settings 일 때 3). 경로 시도 시 사용
# CONFIG_MANAGER_APP_ID=3
# PRODUCT_CODE 조회 전용 URL (실제 API 경로가 다르면 전체 URL 지정)
# CONFIG_MANAGER_PRODUCT_CODES_URL=https://config-manager.ig-pilot.com/api/...

# 완제품 코드 (공정 등록 '대상 완제품')
# IG_CONFIG_API_KEY 설정 시: 코드 관리(config-manager) API에서만 조회. 이 경우 PRODUCT_CODE 는 사용하지 않음(빈 값).
# PRODUCT_CODES_API_URL 설정 시: 해당 URL만 조회.
# config-manager 미사용 시에만: 아래처럼 쉼표 구분으로 입력
# PRODUCT_CODE=CODE1,CODE2
# PRODUCT_CODES_API_URL=https://config-manager.ig-pilot.com/api/...
